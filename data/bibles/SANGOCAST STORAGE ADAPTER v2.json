     * Remove a key.
     * @param {string} key
     * @returns {Promise<boolean>}
     */
    async removeItem(key) {
      return this._adapter.removeItem(this._prefixKey(key));
    }

    // -----------------------------------------------------------------------
    // JSON helpers (auto‑stringify/parse)
    // -----------------------------------------------------------------------

    /**
     * Retrieve and parse a JSON value.
     * @param {string} key
     * @returns {Promise<any>}
     */
    async getJSON(key) {
      const raw = await this.getItem(key);
      if (raw === null) return null;
      try {
        return JSON.parse(raw);
      } catch (e) {
        console.error('[Storage] JSON parse error for key', key, e);
        return null;
      }
    }

    /**
     * Store a value as JSON.
