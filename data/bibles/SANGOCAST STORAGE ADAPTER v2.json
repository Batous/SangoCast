    async keys(prefix = '') {
      const all = await this._adapter.keys(this.prefix + prefix);
      // Remove the instance prefix from returned keys for cleaner API
      return all.map(k => k.slice(this.prefix.length));
    }

    /**
     * Remove all keys that start with the instance prefix.
     * @returns {Promise<boolean>}
     */
    async clearAll() {
      const keys = await this._adapter.keys(this.prefix);
      for (const key of keys) {
        await this._adapter.removeItem(key);
      }
      return true;
    }

    /**
     * Close any open connections (if adapter supports it).
     */
    async close() {
      if (this._adapter.close) {
        await this._adapter.close();
      }
    }
  }

