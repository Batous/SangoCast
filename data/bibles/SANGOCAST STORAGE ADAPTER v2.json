    // Core string‑based methods
    // -----------------------------------------------------------------------

    /**
     * Retrieve a raw string value.
     * @param {string} key
     * @returns {Promise<string|null>}
     */
    async getItem(key) {
      return this._adapter.getItem(this._prefixKey(key));
    }

    /**
     * Store a raw string value.
     * @param {string} key
     * @param {string} value
     * @returns {Promise<boolean>}
