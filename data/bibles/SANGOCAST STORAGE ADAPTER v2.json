  'use strict';

  // =========================================================================
  // 1. Base Adapter Interface (all methods return Promise)
  // =========================================================================

  /**
   * @typedef {Object} StorageAdapter
   * @property {(key: string) => Promise<string|null>} getItem   - returns null if not found
   * @property {(key: string, value: string) => Promise<boolean>} setItem - true on success
   * @property {(key: string) => Promise<boolean>} removeItem
   * @property {(prefix?: string) => Promise<string[]>} keys - returns all keys matching prefix
   * @property {() => Promise<void>} [close] - optional cleanup (for IndexedDB, file handles)
